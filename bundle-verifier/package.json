{
  "name": "bundle-verifier",
  "version": "0.0.1",
  "description": "GitHub Action to verify the committed bundle is up-to-date with the source",
  "main": "index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "compile": "tsc -p .",
    "bundle": "ncc build src/index.ts --source-map --minify"
  },
  "devDependencies": {
    "@types/node": "^26",
    "@vercel/ncc": "^0.44.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@actions/core": "^2.0.0",
    "@actions/exec": "^2.0.0",
    "@actions/io": "^2.0.0"
  }
}
